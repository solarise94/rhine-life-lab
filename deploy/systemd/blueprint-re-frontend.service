[Unit]
Description=Blueprint RE Frontend
After=network.target blueprint-re-backend.service

[Service]
Type=simple
EnvironmentFile=%h/.config/blueprint-re/frontend.env
WorkingDirectory=__FRONTEND_RELEASE_DIR__/frontend
ExecStart=/usr/bin/env HOSTNAME=${FRONTEND_HOST} PORT=${FRONTEND_PORT} __NODE_BIN__ server.js
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
