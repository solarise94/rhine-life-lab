[Unit]
Description=Blueprint RE Manager Pi Agent
After=network.target

[Service]
Type=simple
EnvironmentFile=%h/.config/blueprint-re/manager-agent.env
WorkingDirectory=__RELEASE_ROOT__/manager-agent
ExecStart=__NODE_BIN__ src/server.js
Restart=on-failure
RestartSec=2
TimeoutStopSec=10
KillMode=control-group
SendSIGKILL=yes
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=default.target
