BLUEPRINT_DEEPSEEK_API_BASE_URL=https://api.deepseek.com/anthropic
BLUEPRINT_DEEPSEEK_API_KEY=sk-your-key
BLUEPRINT_PI_DEEPSEEK_BASE_URL=https://api.deepseek.com
# Manager tool-use requests should use a DeepSeek v4 model.
BLUEPRINT_MANAGER_MODEL=deepseek-v4-pro
BLUEPRINT_MANAGER_BACKEND=pi
BLUEPRINT_PI_MANAGER_URL=http://127.0.0.1:18002
BLUEPRINT_BACKEND_API_BASE_URL=http://127.0.0.1:18001/api
BLUEPRINT_INTERNAL_TOOL_TOKEN=change-me
BLUEPRINT_MANAGER_TEMPERATURE=0.2
BLUEPRINT_MANAGER_MAX_TOKENS=2400
BLUEPRINT_MANAGER_TIMEOUT_SECONDS=600
BLUEPRINT_DEFAULT_WORKER_TYPE=pi

# Executor compatibility summary:
# pi is the default and best-supported executor. opencode / claude_code / codex
# are available but partially compatible.
#
# Auth modes:
# - cli_native: wrapper does not inject project API credentials; the CLI uses
#   the host's existing login/config. Native auth directories are read-only
#   inside bwrap, so refresh CLI login on the host first.
# - project_api: wrapper injects project-managed API key/base URL/model into
#   run-scoped env/config. Current support: pi and opencode only.
#
# Support matrix:
# - pi: project_api only, DeepSeek/Pi compatible.
# - opencode: cli_native or project_api, OpenAI-compatible/provider-native.
# - claude_code: cli_native only.
# - codex: cli_native only.
#
# Command-template placeholders:
# {python} {project_root} {run_dir} {result_dir} {task_packet_path}
# {manifest_path} {transcript_path} {executor_brief_path} {executor_prompt_path}
# {adapter_contract_path} {manager_brief_path} {worker_type} {repo_root}
#
# Preferred for all installs: argv JSON templates (safe for paths with spaces).
# Each element is a separate argv entry; placeholders are substituted per-element.
# This is required for robust WSL installs under paths such as
# /mnt/c/Users/<name>/Documents/New project/...
# BLUEPRINT_PI_COMMAND_JSON=["bash","{repo_root}/scripts/blueprint_pi_launch.sh","{executor_prompt_path}"]
# BLUEPRINT_OPENCODE_COMMAND_JSON=["opencode","run","--file","{executor_prompt_path}","--format","json","--dangerously-skip-permissions","Read {executor_prompt_path} and complete the Blueprint executor contract exactly."]
# BLUEPRINT_CLAUDE_CODE_COMMAND_JSON=["claude","-p","@{executor_prompt_path}","--output-format","stream-json","--verbose"]
# BLUEPRINT_CODEX_COMMAND_JSON=["codex","exec","{executor_prompt_path}"]
#
# Legacy string templates are still accepted as fallback, but new installs should
# not rely on them. JSON argv is the long-term path-space-safe format.
# For opencode / pi / claude-code these values are provider CLI launch templates
# consumed by the unified wrapper, not the backend worker command itself.
# Codex currently remains a direct backend command template.
# Replace <tool-specific-args> with the syntax required by your installed CLI.
# In practice, a local wrapper script is often the most stable option across CLI versions.
# BLUEPRINT_OPENCODE_COMMAND=opencode <tool-specific-args> {executor_prompt_path}
# BLUEPRINT_PI_COMMAND=pi --no-session -p @{executor_prompt_path}
# BLUEPRINT_CLAUDE_CODE_COMMAND=claude-code <tool-specific-args> {executor_prompt_path}
# BLUEPRINT_CODEX_COMMAND=codex <tool-specific-args> {executor_prompt_path}
# Example wrapper style:
# BLUEPRINT_OPENCODE_COMMAND=bash /absolute/path/to/opencode-launch.sh {executor_prompt_path}

# Executor runtime isolation. bwrap is a required soft sandbox when enabled;
# deployment must install bubblewrap and pass the sandbox smoke test.
BLUEPRINT_EXECUTOR_SANDBOX_MODE=bwrap
BLUEPRINT_EXECUTOR_MAX_CONCURRENT_RUNS=3
BLUEPRINT_EXECUTOR_CONDA_BASE=/home/solarise/miniconda3
# Soft sandbox default: expose host / read-only for runtime compatibility, then
# mask project forbidden paths and bind only current run outputs writable.
BLUEPRINT_EXECUTOR_HOST_ROOT_READONLY=true
# Optional comma-separated read-only host paths for legacy non-root mode.
BLUEPRINT_EXECUTOR_EXTRA_RO_BINDS=/home/solarise/.nvm,/home/solarise/.local
