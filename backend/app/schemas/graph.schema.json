      "title": "Asset",
      "type": "object"
    },
    "Claim": {
      "properties": {
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "status": {
          "enum": [
            "candidate",
            "valid",
            "stale",
            "superseded",
            "rejected",
            "archived",
            "missing"
          ],
          "title": "Status",
          "type": "string"
