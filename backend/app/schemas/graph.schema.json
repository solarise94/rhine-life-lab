          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "module_id",
        "title",
        "status"
      ],
      "title": "ModuleRef",
      "type": "object"
    },
    "ReportItem": {
      "properties": {
        "item_id": {
          "title": "Item Id",
          "type": "string"
        },
        "section": {
          "title": "Section",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "linked_asset_ids": {
          "items": {
            "type": "string"
          },
          "title": "Linked Asset Ids",
          "type": "array"
