          "title": "Module Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "status": {
          "enum": [
            "proposed",
            "planned",
            "running",
            "reviewing",
            "needs_review",
            "accepted",
            "rejected",
            "stale",
            "superseded",
            "cancelled",
            "failed"
