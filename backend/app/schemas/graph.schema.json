      "required": [
        "claim_id",
        "text",
        "status"
      ],
      "title": "Claim",
      "type": "object"
    },
    "Module": {
      "properties": {
        "module_id": {
          "title": "Module Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "type": {
          "enum": [
            "analysis_module",
            "module_group"
