        "worker_type": {
          "default": "pi",
          "title": "Worker Type",
          "type": "string"
        },
        "cancel_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cancel Reason"
