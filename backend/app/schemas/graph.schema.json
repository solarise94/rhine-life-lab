        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "asset_type": {
          "title": "Asset Type",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "status": {
          "enum": [
            "candidate",
            "valid",
            "stale",
            "superseded",
            "rejected",
            "archived",
            "missing"
          ],
          "title": "Status",
          "type": "string"
        },
        "created_by_run": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created By Run"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "artifact_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Id"
        },
        "depends_on": {
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "report_selected": {
          "default": false,
          "title": "Report Selected",
          "type": "boolean"
        }
      },
      "required": [
        "asset_id",
        "asset_type",
        "title",
        "status",
        "path",
        "summary"
