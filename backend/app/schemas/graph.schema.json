  "properties": {
    "modules": {
      "items": {
        "$ref": "#/$defs/Module"
      },
      "title": "Modules",
      "type": "array"
    },
    "assets": {
      "items": {
        "$ref": "#/$defs/Asset"
      },
      "title": "Assets",
      "type": "array"
    },
    "claims": {
      "items": {
        "$ref": "#/$defs/Claim"
      },
      "title": "Claims",
      "type": "array"
    },
    "runs": {
      "items": {
        "$ref": "#/$defs/RunRecord"
      },
      "title": "Runs",
      "type": "array"
    },
    "report_items": {
      "items": {
        "$ref": "#/$defs/ReportItem"
      },
      "title": "Report Items",
      "type": "array"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    }
  },
  "title": "GraphState",
  "type": "object"
