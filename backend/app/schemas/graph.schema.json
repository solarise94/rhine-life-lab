      "properties": {
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "card_id": {
          "title": "Card Id",
          "type": "string"
        },
        "module_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Module Id"
        },
        "status": {
          "enum": [
            "queued",
            "running",
            "reviewing",
            "needs_approval",
            "success",
            "failed",
            "cancelled",
            "reviewed"
          ],
          "title": "Status",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "started_at": {
          "title": "Started At",
          "type": "string"
        },
        "finished_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finished At"
