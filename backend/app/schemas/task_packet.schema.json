{
  "$defs": {
    "ExecutionPolicy": {
      "properties": {
        "mode": {
          "default": "audit",
          "enum": [
            "audit",
            "guarded",
            "strict"
          ],
          "title": "Mode",
          "type": "string"
        },
        "network": {
          "default": "prompt",
          "title": "Network",
          "type": "string"
        },
        "write_policy": {
          "default": "allowed_paths_with_post_run_audit",
          "title": "Write Policy",
          "type": "string"
        },
        "on_policy_violation": {
          "default": "fail_or_quarantine",
          "title": "On Policy Violation",
          "type": "string"
        }
      },
      "title": "ExecutionPolicy",
      "type": "object"
    },
    "ExecutorContext": {
      "properties": {
        "executor_profile": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Executor Profile"
        },
        "executor_profile_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Executor Profile Id"
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "title": "Skills",
          "type": "array"
        },
        "mcp_servers": {
          "items": {
            "type": "string"
          },
          "title": "Mcp Servers",
          "type": "array"
        },
        "instruction_blocks": {
          "items": {
            "type": "string"
          },
          "title": "Instruction Blocks",
          "type": "array"
        },
        "references": {
          "items": {
            "$ref": "#/$defs/ExecutorReference"
          },
          "title": "References",
          "type": "array"
        },
        "tool_policy": {
          "$ref": "#/$defs/ExecutorToolPolicy"
        },
        "runtime_bindings": {
          "$ref": "#/$defs/RuntimeBindings"
        },
        "script_asset_requirements": {
          "items": {
            "$ref": "#/$defs/ExecutorScriptAssetRequirement"
          },
          "title": "Script Asset Requirements",
          "type": "array"
        },
        "script_asset_bindings": {
          "items": {
            "$ref": "#/$defs/ExecutorScriptAssetBinding"
          },
          "title": "Script Asset Bindings",
          "type": "array"
        },
        "template_metadata": {
          "additionalProperties": true,
          "title": "Template Metadata",
          "type": "object"
        }
      },
      "title": "ExecutorContext",
      "type": "object"
    },
    "ExecutorReference": {
      "properties": {
        "type": {
          "default": "file",
          "enum": [
            "file",
            "directory",
            "url",
            "template"
          ],
          "title": "Type",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "path"
      ],
      "title": "ExecutorReference",
      "type": "object"
    },
    "ExecutorScriptAssetBinding": {
      "properties": {
        "requirement_id": {
          "title": "Requirement Id",
          "type": "string"
        },
        "asset_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asset Id"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "bound_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bound At"
        }
      },
      "required": [
        "requirement_id"
      ],
      "title": "ExecutorScriptAssetBinding",
      "type": "object"
    },
    "ExecutorScriptAssetRequirement": {
      "properties": {
        "requirement_id": {
          "title": "Requirement Id",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "expected_asset_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Asset Type"
        },
        "optional": {
          "default": false,
          "title": "Optional",
          "type": "boolean"
        }
      },
      "required": [
        "requirement_id",
        "label"
      ],
      "title": "ExecutorScriptAssetRequirement",
      "type": "object"
    },
    "ExecutorToolPolicy": {
      "properties": {
        "network": {
          "default": "allow",
          "title": "Network",
          "type": "string"
        },
        "python": {
          "default": true,
          "title": "Python",
          "type": "boolean"
        },
        "rscript": {
          "default": false,
          "title": "Rscript",
          "type": "boolean"
        },
        "shell": {
          "default": true,
          "title": "Shell",
          "type": "boolean"
        },
        "git_write": {
          "default": false,
          "title": "Git Write",
          "type": "boolean"
        }
      },
      "title": "ExecutorToolPolicy",
      "type": "object"
    },
    "ManagerReportingContract": {
      "properties": {
        "transport": {
          "default": "stdout_bp_event",
          "enum": [
            "stdout_bp_event",
            "file_jsonl"
          ],
          "title": "Transport",
          "type": "string"
        },
        "stdout_prefix": {
          "default": "BP_EVENT ",
          "title": "Stdout Prefix",
          "type": "string"
        },
        "file_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File Path"
        },
        "message_types": {
          "items": {
            "type": "string"
          },
          "title": "Message Types",
          "type": "array"
        }
      },
      "title": "ManagerReportingContract",
      "type": "object"
    },
    "RunContext": {
      "properties": {
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "worker_type": {
          "title": "Worker Type",
          "type": "string"
        },
        "project_root": {
          "title": "Project Root",
          "type": "string"
        },
        "run_dir": {
          "title": "Run Dir",
          "type": "string"
        },
        "result_dir": {
          "title": "Result Dir",
          "type": "string"
        }
      },
      "required": [
        "run_id",
        "worker_type",
        "project_root",
        "run_dir",
        "result_dir"
      ],
      "title": "RunContext",
      "type": "object"
    },
    "RuntimeBindings": {
      "properties": {
        "conda_env": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Conda Env"
        },
        "r_env": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "R Env"
        },
        "container_image": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Container Image"
        },
        "working_dir": {
          "default": ".",
          "title": "Working Dir",
          "type": "string"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Env",
          "type": "object"
        }
      },
      "title": "RuntimeBindings",
      "type": "object"
    },
    "TaskOutputSpec": {
      "properties": {
        "role": {
          "title": "Role",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "artifact_class": {
          "enum": [
            "figure",
            "table",
            "document",
            "model",
            "archive",
            "binary"
          ],
          "title": "Artifact Class",
          "type": "string"
        },
        "accepted_formats": {
          "items": {
            "type": "string"
          },
          "title": "Accepted Formats",
          "type": "array"
        },
        "preferred_format": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preferred Format"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "path_hint": {
          "title": "Path Hint",
          "type": "string"
        },
        "asset_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asset Id"
        },
        "status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status"
        }
      },
      "required": [
        "role",
        "label",
        "artifact_class",
        "path_hint"
      ],
      "title": "TaskOutputSpec",
      "type": "object"
    },
    "TaskPacketAsset": {
      "properties": {
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status"
        }
      },
      "required": [
        "asset_id",
        "path",
        "type"
      ],
      "title": "TaskPacketAsset",
      "type": "object"
    },
    "TaskPacketCardInput": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "asset_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asset Id"
        },
        "asset_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asset Path"
        },
        "asset_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asset Type"
        },
        "status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status"
        }
      },
      "required": [
        "label"
      ],
      "title": "TaskPacketCardInput",
      "type": "object"
    }
  },
  "properties": {
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "card_id": {
      "title": "Card Id",
      "type": "string"
    },
    "card_title": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Card Title"
    },
    "card_status": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Card Status"
    },
    "goal": {
      "title": "Goal",
      "type": "string"
    },
    "input_assets": {
      "items": {
        "$ref": "#/$defs/TaskPacketAsset"
      },
      "title": "Input Assets",
      "type": "array"
    },
    "card_inputs": {
      "items": {
        "$ref": "#/$defs/TaskPacketCardInput"
      },
      "title": "Card Inputs",
      "type": "array"
    },
    "card_outputs": {
      "items": {
        "$ref": "#/$defs/TaskOutputSpec"
      },
      "title": "Card Outputs",
      "type": "array"
    },
    "expected_outputs": {
      "items": {
        "$ref": "#/$defs/TaskOutputSpec"
      },
      "title": "Expected Outputs",
      "type": "array"
    },
    "allowed_paths": {
      "items": {
        "type": "string"
      },
      "title": "Allowed Paths",
      "type": "array"
    },
    "readonly_paths": {
      "items": {
        "type": "string"
      },
      "title": "Readonly Paths",
      "type": "array"
    },
    "forbidden_paths": {
      "items": {
        "type": "string"
      },
      "title": "Forbidden Paths",
      "type": "array"
    },
    "execution_policy": {
      "$ref": "#/$defs/ExecutionPolicy"
    },
    "constraints": {
      "items": {
        "type": "string"
      },
      "title": "Constraints",
      "type": "array"
    },
    "worker_instructions": {
      "title": "Worker Instructions",
      "type": "string"
    },
    "run_context": {
      "anyOf": [
        {
          "$ref": "#/$defs/RunContext"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "executor_context": {
      "anyOf": [
        {
          "$ref": "#/$defs/ExecutorContext"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "manager_reporting_contract": {
      "anyOf": [
        {
          "$ref": "#/$defs/ManagerReportingContract"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "task_id",
    "project_id",
    "card_id",
    "goal",
    "worker_instructions"
  ],
  "title": "TaskPacket",
  "type": "object"
}
